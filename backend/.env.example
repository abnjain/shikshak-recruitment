# Server
SERVER_PORT=8080

# PostgreSQL Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/shikshak_recruitment
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-password

# JWT
APP_JWT_SECRET=your-base64-encoded-256-bit-secret-key
APP_JWT_EXPIRATION_MS=86400000

# Google OAuth
APP_OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional: MySQL (comment out PostgreSQL above and uncomment below for MySQL)
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/shikshak_recruitment?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=your-password
# SPRING_JPA_DATABASE-PLATFORM=org.hibernate.dialect.MySQLDialect
